import torch
from diffusers import StableVideoDiffusionPipeline
from diffusers.utils import load_image, export_to_video

# 1. ماڈل لوڈ کرنے کا فنکشن
def load_model():
    print("ماڈل لوڈ ہو رہا ہے، براہ کرم انتظار کریں...")
    pipe = StableVideoDiffusionPipeline.from_pretrained(
        "stabilityai/stable-video-diffusion-img2vid-xt", 
        torch_dtype=torch.float16, 
        variant="fp16"
    )
    pipe.enable_model_cpu_offload() # میموری بچانے کے لیے
    return pipe

# 2. ویڈیو بنانے کا فنکشن
def generate_video(image_path, output_path="output_video.mp4"):
    pipe = load_model()
    
    # تصویر لوڈ کریں
    image = load_image(image_path)
    image = image.resize((1024, 576)) # ویڈیو کے سائز کے مطابق
    
    print("ویڈیو بن رہی ہے...")
    generator = torch.manual_seed(42)
    frames = pipe(image, decode_chunk_size=8, generator=generator).frames[0]
    
    # ویڈیو سیو کریں
    export_to_video(frames, output_path, fps=7)
    print(f"آپ کی ویڈیو تیار ہے اور اس نام سے سیو ہو گئی ہے: {output_path}")

